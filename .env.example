# ConnectSphere Environment Variables
# Copy this file to .env and fill in values

SECRET_KEY=your-super-secret-key-change-this
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Instagram Integration via Instagrapi (no Meta Developer App required)
# Use a real Instagram account (preferably a dedicated/burner account)
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password
# Optional: path to persist the login session (avoids re-login on every restart)
INSTAGRAM_SESSION_FILE=instagram_session.json
